```

### 3.2 WebSocket Message Protocol

All messages are UTF-8 encoded JSON. Every message has a `type: string` discriminant.

```typescript
// Client → Server (from phone or desktop)
type ClientMessage =
  | {
      type: "identify";
      clientId: string;
      role: "phone" | "desktop";
      experimentId: string;
    }
  | {
      type: "join";
      roomId: string;
      clientId: string;
      role: "phone" | "desktop";
    }
  | { type: "offer"; from: string; to: string; sdp: RTCSessionDescriptionInit }
  | { type: "answer"; from: string; to: string; sdp: RTCSessionDescriptionInit }
  | { type: "ice"; from: string; to: string; candidate: RTCIceCandidateInit };

// Server → Client (status events to desktop)
type ServerMessage =
  | { type: "peer-joined"; roomId: string; clientId: string; role: string }
  | { type: "peer-left"; roomId: string; clientId: string }
  | { type: "peer-unavailable"; to: string }
  | { type: "upload-received"; experimentId: string; cameraId: number }
  | { type: "extraction-started"; experimentId: string; cameraId: number }
  | {
      type: "extraction-complete";
      experimentId: string;
      cameraId: number;
      frameCount: number;
    }
  | {
      type: "extraction-failed";
      experimentId: string;
      cameraId: number;
      error: string;
    }
  | { type: "job-started"; jobId: string; experimentId: string }
  | {
      type: "job-progress";
      jobId: string;
      frame: number;
      progress: number;
      points: TrackedPointWS[];
    }
  | { type: "job-complete"; jobId: string; results: PhysicsResultWS }
  | { type: "job-failed"; jobId: string; error: string }
  | { type: "error"; message: string };

interface TrackedPointWS {
  ballId: number;
  cameraId: number;
  x: number; // float32, pixels
  y: number; // float32, pixels
  confidence: number; // float32, 0.0–1.0
}
```

### 3.3 gRPC Interface

The canonical definition lives in `proto/physics.proto`. The Node gRPC client is generated from it. Reproduced here for completeness:

```protobuf
syntax = "proto3";
package physicscapture;

service PhysicsCapture {
  rpc RunCalibration (CalibrationRequest)  returns (stream CalibrationStatus);
  rpc TrackBalls     (TrackingRequest)     returns (stream TrackingStatus);
  rpc ComputePhysics (PhysicsRequest)      returns (PhysicsResult);
}

message CalibrationRequest {
  string experiment_id = 1;
  int32  camera_id     = 2;
}
message CalibrationStatus {
  float  progress        = 1;
  float  reprojection_error_px = 2;
  bool   complete        = 3;
  string error           = 4;
}

message TrackingRequest {
  string            experiment_id = 1;
  repeated BallSeed seeds         = 2;
}
message BallSeed {
  int32 camera_id  = 1;
  int32 frame_idx  = 2;   // 0-based
  float x          = 3;   // pixels
  float y          = 4;   // pixels
  int32 ball_id    = 5;   // 0–2
}
message TrackingStatus {
  int32                  frame           = 1;
  float                  progress        = 2;   // 0.0–1.0
  repeated TrackedPoint  points          = 3;
  bool                   complete        = 4;
  string                 error           = 5;
}
message TrackedPoint {
  int32 ball_id    = 1;
  int32 camera_id  = 2;
  float x          = 3;
  float y          = 4;
  float confidence = 5;
}

message PhysicsRequest {
  string experiment_id  = 1;
  repeated BallMass masses = 2;
}
message BallMass {
  int32 ball_id                 = 1;
  float mass_kg                 = 2;
  float mass_uncertainty_kg     = 3;
}
message PhysicsResult {
  repeated BallResult balls  = 1;
  SystemResult        system = 2;
  string              error  = 3;
}
message BallResult {
  int32 ball_id               = 1;
  float v_before              = 2;   // m/s
  float v_before_uncertainty  = 3;
  float v_after               = 4;
  float v_after_uncertainty   = 5;
  float momentum_before       = 6;
  float momentum_before_uncertainty = 7;
  float momentum_after        = 8;
  float momentum_after_uncertainty  = 9;
}
message SystemResult {
  float total_momentum_before             = 1;
  float total_momentum_before_uncertainty = 2;
  float total_momentum_after              = 3;
  float total_momentum_after_uncertainty  = 4;
  float ke_before                         = 5;
  float ke_after                          = 6;
  float conservation_error_pct            = 7;
  float restitution_coeff                 = 8;
}
```

### 3.4 WebSocket Job Status Event Schema

All `job-progress` messages include a `progress` field: `float32` in range `[0.0, 1.0]`, representing fraction of frames processed.

### 3.5 SQLite Schema

```sql
-- experiments.db

CREATE TABLE experiments (
  id           TEXT PRIMARY KEY,   -- UUID v4
  created_at   INTEGER NOT NULL,   -- Unix epoch ms
  session_notes TEXT,
  status       TEXT NOT NULL       -- 'CREATED' | 'PARTIAL_UPLOAD' | 'EXTRACTION' | 'READY' | 'PROCESSING' | 'COMPLETE' | 'FAILED'
    CHECK(status IN ('CREATED','PARTIAL_UPLOAD','EXTRACTION','READY','PROCESSING','COMPLETE','FAILED'))
);

CREATE TABLE cameras (
  experiment_id      TEXT NOT NULL REFERENCES experiments(id),
  camera_id          INTEGER NOT NULL,  -- 0 or 1
  label              TEXT,
  upload_status      TEXT NOT NULL DEFAULT 'PENDING'  -- 'PENDING' | 'UPLOADED' | 'FAILED'
    CHECK(upload_status IN ('PENDING','UPLOADED','FAILED')),
  uploaded_at        INTEGER,           -- Unix epoch ms, null until uploaded
  extraction_status  TEXT NOT NULL DEFAULT 'PENDING'  -- 'PENDING' | 'IN_PROGRESS' | 'COMPLETE' | 'FAILED'
    CHECK(extraction_status IN ('PENDING','IN_PROGRESS','COMPLETE','FAILED')),
  extraction_started_at INTEGER,
  extraction_complete_at INTEGER,
  frame_count        INTEGER,           -- null until extraction complete
  extraction_error   TEXT,
  PRIMARY KEY (experiment_id, camera_id)
);

CREATE TABLE balls (
  experiment_id           TEXT NOT NULL REFERENCES experiments(id),
  ball_id                 INTEGER NOT NULL,  -- 0, 1, 2
  mass_grams              REAL NOT NULL,
  mass_uncertainty_grams  REAL NOT NULL DEFAULT 1.0,
  PRIMARY KEY (experiment_id, ball_id)
);

CREATE TABLE jobs (
  id             TEXT PRIMARY KEY,   -- UUID v4
  experiment_id  TEXT NOT NULL REFERENCES experiments(id),
  type           TEXT NOT NULL,      -- 'tracking' | 'physics' | 'calibration'
  status         TEXT NOT NULL DEFAULT 'QUEUED'
    CHECK(status IN ('QUEUED','RUNNING','COMPLETE','FAILED','CANCELLED')),
  created_at     INTEGER NOT NULL,
  started_at     INTEGER,
  completed_at   INTEGER,
  error          TEXT,
  result_json    TEXT               -- JSON string of PhysicsResult, null until complete
);
