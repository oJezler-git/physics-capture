## 4. Algorithmic Implementation

### 4.1 WebRTC Signaling Relay Algorithm

The signaling hub implements a stateless relay; it does not parse SDP or ICE candidates — it forwards them.

```
STATE:
  rooms: Map<roomId: string, {
    members: Map<clientId: string, {
      ws: WebSocket,
      role: "phone" | "desktop"
    }>
  }>
  clients: Map<clientId: string, roomId: string>  // reverse index

ON message received from ws client:
  1. Parse JSON → msg
  2. If msg.type == "identify":
       clientId = msg.clientId
       ws.clientId = clientId  // attach to socket object
       clients.set(clientId, msg.experimentId)
       RETURN

  3. If msg.type == "join":
       roomId = msg.roomId
       If rooms.has(roomId) == false: rooms.set(roomId, { members: new Map() })
       room = rooms.get(roomId)
       room.members.set(msg.clientId, { ws, role: msg.role })
       clients.set(msg.clientId, roomId)
       // Notify existing members
       FOR each (existingId, existing) IN room.members WHERE existingId != msg.clientId:
         send(existing.ws, { type: "peer-joined", roomId, clientId: msg.clientId, role: msg.role })
         send(ws, { type: "peer-joined", roomId, clientId: existingId, role: existing.role })
       RETURN

  4. If msg.type IN ["offer", "answer", "ice"]:
       roomId = clients.get(msg.from)
       IF roomId == undefined: send(ws, { type: "error", message: "not in room" }); RETURN
       room = rooms.get(roomId)
       target = room.members.get(msg.to)
       IF target == undefined:
         send(ws, { type: "peer-unavailable", to: msg.to }); RETURN
       send(target.ws, msg)  // forward verbatim
       RETURN

ON ws close:
  clientId = ws.clientId
  roomId = clients.get(clientId)
  IF roomId:
    room = rooms.get(roomId)
    room.members.delete(clientId)
    clients.delete(clientId)
    // Notify remaining members
    FOR each (id, member) IN room.members:
      send(member.ws, { type: "peer-left", roomId, clientId })
    // Clean up empty rooms
    IF room.members.size == 0: rooms.delete(roomId)
```

### 4.2 File Upload + Extraction Pipeline

```
FUNCTION handleUpload(req, res):
  1. experimentId = req.params.experimentId
  2. cameraId = parseInt(req.params.cameraId)  // must be 0 or 1

  3. VALIDATE:
       IF NOT db.experimentExists(experimentId): return 404
       IF cameraId NOT IN [0, 1]: return 400

  4. multer runs disk storage:
       destination = /experiments/{experimentId}/raw/
       filename = cam{cameraId}.webm  (or .mp4 if mime is video/mp4)

  5. ON multer complete:
       db.updateCameraUpload(experimentId, cameraId, {
         upload_status: "UPLOADED",
         uploaded_at: Date.now()
       })
       updateMetadataJson(experimentId)
       wsBroadcast({ type: "upload-received", experimentId, cameraId })

  6. TRIGGER async (do not await):
       ffmpegManager.extract(experimentId, cameraId)

  7. RETURN HTTP 202: { message: "upload received", experimentId, cameraId }


FUNCTION FfmpegManager.extract(experimentId, cameraId):
  1. inputPath = resolveInputPath(experimentId, cameraId)
     // checks for .webm first, then .mp4
  2. outputDir = /experiments/{experimentId}/frames/cam{cameraId}/
  3. fs.mkdirSync(outputDir, { recursive: true })

  4. db.updateExtractionStatus(experimentId, cameraId, {
       extraction_status: "IN_PROGRESS",
       extraction_started_at: Date.now()
     })
  5. wsBroadcast({ type: "extraction-started", experimentId, cameraId })

  6. cmd = ["ffmpeg", "-i", inputPath, "-vsync", "0", "-f", "image2",
             path.join(outputDir, "frame_%06d.png")]
     proc = child_process.spawn(cmd[0], cmd.slice(1), { stdio: ["ignore","pipe","pipe"] })
     // stdout unused; stderr contains ffmpeg progress

  7. stderrChunks = []
     proc.stderr.on("data", chunk => {
       stderrChunks.push(chunk)
       log.debug("ffmpeg", chunk.toString())
     })

  8. AWAIT proc exit:
       IF exitCode == 0:
         pngFiles = fs.readdirSync(outputDir).filter(f => f.endsWith(".png")).sort()
         frameCount = pngFiles.length
         IF frameCount == 0:
           GOTO extraction-failed("ffmpeg produced 0 frames")

         db.updateExtractionStatus(experimentId, cameraId, {
           extraction_status: "COMPLETE",
           extraction_complete_at: Date.now(),
           frame_count: frameCount
         })
         updateMetadataJson(experimentId)
         wsBroadcast({ type: "extraction-complete", experimentId, cameraId, frameCount })
         jobQueue.emit("extraction-complete", { experimentId, cameraId })
         RETURN

       ELSE:
         stderrTail = Buffer.concat(stderrChunks).toString().slice(-2000)
         db.updateExtractionStatus(experimentId, cameraId, {
           extraction_status: "FAILED",
           extraction_error: stderrTail
         })
         wsBroadcast({ type: "extraction-failed", experimentId, cameraId, error: stderrTail })
```

### 4.3 Job Queue Algorithm

```
STATE:
  queue: Array<Job>          // ordered FIFO
  activeJob: Job | null = null

FUNCTION enqueue(jobRequest):
  jobId = uuid()
  job = {
    id: jobId,
    experimentId: jobRequest.experimentId,
    type: jobRequest.type,
    seeds: jobRequest.seeds,
    status: "QUEUED",
    createdAt: Date.now()
  }
  db.insertJob(job)
  queue.push(job)
  tryDispatch()
  RETURN jobId


FUNCTION tryDispatch():
  IF activeJob != null: RETURN  // another job is running
  IF queue.length == 0: RETURN
  job = queue.shift()
  activeJob = job

  db.updateJob(job.id, { status: "RUNNING", started_at: Date.now() })
  wsBroadcast({ type: "job-started", jobId: job.id, experimentId: job.experimentId })

  // All extractions must be complete before dispatching
  cameras = db.getCamerasForExperiment(job.experimentId)
  notReady = cameras.filter(c => c.extraction_status != "COMPLETE")
  IF notReady.length > 0:
    wsBroadcast({ type: "job-failed", jobId: job.id,
                  error: `Camera ${notReady[0].camera_id} extraction not complete` })
    db.updateJob(job.id, { status: "FAILED", error: "extraction not complete" })
    activeJob = null
    tryDispatch()
    RETURN

  TRY:
    IF job.type == "tracking":
      AWAIT runTrackingJob(job)
    ELSE IF job.type == "calibration":
      AWAIT runCalibrationJob(job)
    ELSE IF job.type == "physics":
      AWAIT runPhysicsJob(job)
  CATCH err:
    handleJobError(job, err)
  FINALLY:
    activeJob = null
    tryDispatch()  // process next job


FUNCTION runTrackingJob(job):
  stream = grpcClient.trackBalls({
    experiment_id: job.experimentId,
    seeds: job.seeds.map(s => ({
      camera_id: s.cameraId,
      frame_idx: s.frameIdx,
      x: s.x, y: s.y,
      ball_id: s.ballId
    }))
  })
  FOR AWAIT msg OF stream:
    IF msg.error:
      THROW new Error(msg.error)
    wsBroadcast({
      type: "job-progress",
      jobId: job.id,
      frame: msg.frame,
      progress: msg.progress,
      points: msg.points.map(p => ({
        ballId: p.ball_id, cameraId: p.camera_id,
        x: p.x, y: p.y, confidence: p.confidence
      }))
    })
    IF msg.complete: BREAK

  db.updateJob(job.id, { status: "COMPLETE", completed_at: Date.now() })
  wsBroadcast({ type: "job-complete", jobId: job.id })
```

### 4.4 gRPC Streaming Consumption Pattern

`@grpc/grpc-js` returns a `ClientReadableStream`. We wrap it as an `AsyncIterator` for clean `for-await` consumption:

```typescript
function streamToAsyncIterator<T>(
  stream: ClientReadableStream<T>,
): AsyncIterable<T> {
  return {
    [Symbol.asyncIterator](): AsyncIterator<T> {
      const queue: T[] = [];
      let done = false;
      let error: Error | null = null;
      let resolve: (() => void) | null = null;

      stream.on("data", (msg: T) => {
        queue.push(msg);
        resolve?.();
        resolve = null;
      });
      stream.on("end", () => {
        done = true;
        resolve?.();
        resolve = null;
      });
      stream.on("error", (err: Error) => {
        error = err;
        resolve?.();
        resolve = null;
      });

      return {
        async next(): Promise<IteratorResult<T>> {
          while (true) {
            if (queue.length > 0) {
              return { value: queue.shift()!, done: false };
            }
            if (error) throw error;
            if (done) return { value: undefined as any, done: true };
            await new Promise<void>((r) => {
              resolve = r;
            });
          }
        },
      };
    },
  };
}
```

