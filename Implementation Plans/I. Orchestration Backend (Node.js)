## 3. Data Contracts & Interfaces

### 3.1 HTTP API

```typescript
// POST /experiments
interface CreateExperimentRequest {
  balls: Array<{
    ballId: number; // uint8, 0–2
    massGrams: number; // float64, > 0
    massUncertaintyGrams: number; // float64, > 0, default 1.0
  }>;
  sessionNotes?: string;
}
interface CreateExperimentResponse {
  experimentId: string; // UUID v4
  createdAt: string; // ISO 8601 UTC
}

// POST /upload/:experimentId/:cameraId
// Content-Type: multipart/form-data
// Field: video (binary)
// Response: 202 Accepted
interface UploadAckResponse {
  message: "upload received";
  experimentId: string;
  cameraId: number;
}

// POST /jobs
interface SubmitJobRequest {
  experimentId: string;
  type: "tracking" | "physics" | "calibration";
  seeds?: Array<{
    cameraId: number; // 0 or 1
    frameIdx: number; // uint32, 0-based
    x: number; // float32, pixels
    y: number; // float32, pixels
