      "frame_count": 1800,
      "fit_slope_px_per_frame": 19.839,
      "fit_intercept_px": 20.1,
      "fit_r_squared": 0.9997,
      "fit_residual_rms_px": 0.52,
      "timestamp_ms": [13.74, 47.11, 80.47, "..."]
    }
