// Stop recording on all phones
{ type: 'record:stop', experimentId: string }

// WebRTC signaling
{ type: 'peer:answer', peerId: string, data: RTCSessionDescriptionInit }
{ type: 'peer:ice', peerId: string, data: RTCIceCandidateInit }
