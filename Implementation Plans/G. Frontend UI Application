{ type: 'phone:joined', peerId: string, label: string }

// WebRTC signaling from phone
{ type: 'peer:offer', peerId: string, data: RTCSessionDescriptionInit }
{ type: 'peer:ice', peerId: string, data: RTCIceCandidateInit }

