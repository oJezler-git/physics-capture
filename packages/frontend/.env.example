# Host shown in QR codes so phones can reach the PC (local IP or public tunnel domain).
# Only needed when accessing the app from localhost but phones need a different URL.
# Leave blank to auto-detect from window.location.hostname (works for LAN and ngrok).
VITE_APP_HOST=

# Explicit WebSocket URL override. Leave blank to auto-derive from window.location.hostname.
# Only needed for split-tunnel setups where the WS backend is on a different host/port.
VITE_WS_URL=
